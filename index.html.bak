        </div>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero-gradient relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <!-- Left: Text Content -->
        <div class="text-center lg:text-left">
