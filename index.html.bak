              <a href="#" class="block px-4 py-2 text-sm hover:bg-blush-light cursor-pointer">All Nails</a>
              <a href="#" class="block px-4 py-2 text-sm hover:bg-blush-light cursor-pointer">Press-On Sets</a>
              <a href="#" class="block px-4 py-2 text-sm hover:bg-blush-light cursor-pointer">Nail Charms</a>
              <a href="#" class="block px-4 py-2 text-sm hover:bg-blush-light cursor-pointer">Gel Extensions</a>
              <a href="#" class="block px-4 py-2 text-sm hover:bg-blush-light cursor-pointer">Accessories</a>
            </div>
          </a>
          <a href="#" class="font-medium text-sm hover:text-rose transition-colors cursor-pointer">COLLECTIONS</a>
          <a href="#" class="font-medium text-sm hover:text-rose transition-colors cursor-pointer">ABOUT</a>
          <a href="#" class="font-medium text-sm hover:text-rose transition-colors cursor-pointer">JOURNAL</a>
        </nav>

        <!-- Logo -->
        <a href="#" class="absolute left-1/2 -translate-x-1/2 lg:static lg:translate-x-0 lg:mx-auto">
          <h1 class="font-heading text-2xl lg:text-3xl font-bold tracking-wide cursor-pointer">
            <span class="gradient-text">EULYNE</span>
          </h1>
        </a>

        <!-- Right Icons -->
        <div class="flex items-center gap-4">
          <button class="p-2 hover:text-rose transition-colors cursor-pointer" aria-label="Search">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </button>
          <button class="p-2 hover:text-rose transition-colors cursor-pointer" aria-label="Account">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </button>
          <button class="p-2 hover:text-rose transition-colors cursor-pointer relative" aria-label="Cart">
