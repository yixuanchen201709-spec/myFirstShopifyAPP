          <!-- Decorative Elements -->
          <div class="absolute -top-8 -right-8 w-32 h-32 bg-gold-light/30 rounded-full blur-2xl"></div>
          <div class="absolute -bottom-8 -left-8 w-40 h-40 bg-blush-dark/40 rounded-full blur-2xl"></div>

          <!-- Main Image Container -->
          <div class="relative rounded-3xl overflow-hidden shadow-2xl animate-float">
            <img
              src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=800&h=1000&fit=crop"
              alt="Luxury press-on nails with African inspired patterns"
              class="w-full h-[400px] lg:h-[500px] object-cover"
            >
            <!-- Overlay Badge -->
            <div class="absolute bottom-6 left-6 bg-white/95 backdrop-blur-sm rounded-2xl px-6 py-4 shadow-lg">
              <p class="text-sm font-semibold text-charcoal">Handcrafted with love</p>
              <p class="text-xs text-warmgray">Inspired by African heritage</p>
            </div>
          </div>

          <!-- Floating Product Card -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-4 shadow-xl border border-blush-light">
            <img
