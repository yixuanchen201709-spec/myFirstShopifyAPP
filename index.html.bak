          </svg>
        </button>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-8">
          <a href="#" class="nav-item relative font-medium text-sm hover:text-rose transition-colors cursor-pointer">
            SHOP
